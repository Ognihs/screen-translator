API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o
DEFAULT_INTERVAL=10.0
# JPEG 压缩质量 (1-95, 默认 75, 值越小文件越小但画质越差)
JPEG_QUALITY=75
# 推理深度 (none/low/medium/high, 留空则使用模型默认行为)
REASONING_EFFORT=
# 稳定性检测轮询间隔（毫秒, 默认 200, 范围 50-2000）
STABILITY_POLL_INTERVAL=200
# 稳定性滑动窗口大小（连续稳定次数, 默认 5, 范围 2-20）
STABILITY_WINDOW_SIZE=5
# 稳定性 MSE 阈值（低于此值视为稳定, 默认 50.0, 范围 0.0-10000.0）
STABILITY_MSE_THRESHOLD=50.0
# 内容变化阈值（RMSE% 超过此值视为变化, 默认 1.0, 范围 0.0-100.0）
STABILITY_CHANGE_THRESHOLD=1.0
